# ── Docker Compose Local — Variables de entorno ───────────────
# Copiar a .env.local y completar con los valores reales.
# Uso: docker compose -f docker-compose.local.yml up -d

# ── Database principal ─────────────────────────────────────────
DATABASE_URL=postgresql://dbcontrol:changeme@localhost:5432/dbcontrol
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dbcontrol
DB_USER=dbcontrol
DB_PASSWORD=changeme

# ── Server ─────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173

# ── Keycloak (instancia externa en la nube) ────────────────────
KEYCLOAK_URL=https://<your-keycloak-url>/
KEYCLOAK_REALM=<realm>
KEYCLOAK_CLIENT_ID=<client-id-api>

# ── Cloudflare R2 ──────────────────────────────────────────────
R2_ACCOUNT_ID=<your-cloudflare-account-id>
R2_ACCESS_KEY_ID=<your-r2-access-key-id>
R2_SECRET_ACCESS_KEY=<your-r2-secret-access-key>
R2_BUCKET_NAME=<bucket-name>
R2_PUBLIC_BASE_URL=https://<your-r2-public-url>/

# ── Vite (runtime para web container, build-time para dev local) ─
# En docker-compose.local.yml (dev): Vite lee import.meta.env directo
# En docker-compose.yml (production): entrypoint.sh inyecta en config.js
VITE_API_URL=http://localhost:3000
VITE_KEYCLOAK_URL=https://<your-keycloak-url>/
VITE_KEYCLOAK_REALM=<realm>
VITE_KEYCLOAK_CLIENT_ID=<client-id-web>
VITE_APP_BASE_URL=http://localhost:5173
