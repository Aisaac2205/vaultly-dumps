# ── Docker Compose Local — Variables de entorno ───────────────
# Copiar a .env.local y completar con los valores reales.
# Uso: docker compose -f docker-compose.local.yml up -d

# ── Database principal ─────────────────────────────────────────
DATABASE_URL=postgresql://dbcontrol:changeme@localhost:5432/dbcontrol

# ── Server ─────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173

# ── Cloudflare R2 ──────────────────────────────────────────────
R2_ACCOUNT_ID=<your-cloudflare-account-id>
R2_ACCESS_KEY_ID=<your-r2-access-key-id>
R2_SECRET_ACCESS_KEY=<your-r2-secret-access-key>
R2_BUCKET_NAME=<bucket-name>
R2_PUBLIC_BASE_URL=https://<your-r2-public-url>/

# ── Vite (runtime para web container, build-time para dev local) ─
# En docker-compose.local.yml (dev): Vite lee import.meta.env directo
# En docker-compose.yml (production): entrypoint.sh inyecta en config.js
VITE_API_URL=http://localhost:3000


# ── Encryption de PassWord
ENCRYPTION_KEY=<random-32-char-secret>

# ── Better Auth ────────────────────────────────────────────────
BETTER_AUTH_SECRET=<random-32-char-secret>
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_ADMIN_EMAIL=admin@vaultly.local
BETTER_AUTH_ADMIN_PASSWORD=<min-8-chars>
