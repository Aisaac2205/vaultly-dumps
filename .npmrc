shamefully-hoist=false
strict-peer-dependencies=false
auto-install-peers=true
link-workspace-packages=true

# pnpm v10+ requiere esto para `pnpm deploy` (en vez de --legacy).
# Cuando un paquete del workspace consume otro con "workspace:*",
# inject COPIA los archivos en lugar de symlinkear — así el bundle
# final de prod es standalone y no depende del layout del workspace.
# Hoy es no-op (no hay paquetes internos compartidos); el día que
# se agregue @vaultly-control/shared o similar, ya está listo.
inject-workspace-packages=true
